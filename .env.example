# STRAVA API
# _strava4_session cookie from browser (expires every 2-4 weeks)
STRAVA_SESSION_COOKIE=xxx

# Club ID from strava.com/clubs/XXXXX
STRAVA_CLUB_ID=xxx

# LEADERBOARD
LEADERBOARD_MIN_RUNNERS=20
LEADERBOARD_KM_CUTOFF=30

# SCHEDULE (Budapest time)
SCHEDULE_DAY=monday
SCHEDULE_TIME=00:05

# TELEGRAM
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx
TELEGRAM_THREAD_ID=xxx
TELEGRAM_CAPTION=Вот лидерборд этой недели!

# COOKIE HEALTH CHECK
# How often to check if the Strava cookie is still valid (minutes)
COOKIE_CHECK_INTERVAL_MINUTES=180

# Bot Owners notified when the cookie expires (comma-separated Telegram chat IDs)
TELEGRAM_ALERT_IDS=xxx

# Message sent to the group when the weekly leaderboard fails due to expired cookie
LEADERBOARD_FAILURE_MESSAGE=К сожалению, токен Strava истёк, и админы ещё не обновили его. Лидерборд на этой неделе не сформирован. Свяжитесь с админами, чтобы исправить.
