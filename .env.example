# STRAVA API
# _strava4_session cookie from browser (expires every 2-4 weeks)
STRAVA_SESSION_COOKIE=xxx

# Club ID from strava.com/clubs/XXXXX
STRAVA_CLUB_ID=xxx

# LEADERBOARD
LEADERBOARD_MIN_RUNNERS=20
LEADERBOARD_KM_CUTOFF=30

# SCHEDULE (Budapest time)
SCHEDULE_DAY=monday
SCHEDULE_TIME=00:05

# TELEGRAM
TELEGRAM_BOT_TOKEN=xxx
TELEGRAM_CHAT_ID=xxx
TELEGRAM_THREAD_ID=xxx
TELEGRAM_CAPTION=Вот лидерборд этой недели!
